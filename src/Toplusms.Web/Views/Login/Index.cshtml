@{
    ViewData["Title"] = "Giriş Yap";
}
<div class="login-card bg-white p-5" style="width:100%;max-width:420px">
    <div class="text-center mb-4">
        <div class="bg-dark text-white rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;font-size:1.5rem;font-weight:700">S</div>
        <h4 class="fw-bold">Toplusms.link</h4>
        <p class="text-muted" style="font-size:0.9rem">SMS Yönetim Paneli</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger py-2" style="font-size:0.85rem">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form method="post">
        <div class="mb-3">
            <label class="form-label" style="font-size:0.85rem">Kullanıcı Adı</label>
            <input type="text" name="username" class="form-control form-control-lg" placeholder="Kullanıcı adınız" required />
        </div>
        <div class="mb-4">
            <label class="form-label" style="font-size:0.85rem">Şifre</label>
            <input type="password" name="password" class="form-control form-control-lg" placeholder="Şifreniz" required />
        </div>
        <button type="submit" class="btn btn-dark btn-lg w-100">Giriş Yap</button>
        <div class="text-center mt-3">
            <a href="#" class="text-decoration-none" style="font-size:0.85rem">Şifremi Unuttum</a>
        </div>
    </form>
</div>
